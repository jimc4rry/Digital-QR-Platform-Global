# Copy this file to .env and fill in the values for your environment.

# Core Django settings
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://127.0.0.1:8000

# Database (optional - defaults to local SQLite if unset)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# S3-compatible media storage (optional - defaults to local disk storage if unset)
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=

# CORS - comma-separated origins allowed to call the API (e.g. the mobile app in production)
# Ignored in DEBUG mode, where all origins are allowed.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# CSRF - comma-separated HTTPS origins allowed to submit forms to the dashboard, beyond
# ALLOWED_HOSTS. Needed when testing through a tunnel (e.g. ngrok) since Paddle checkout
# requires a real HTTPS domain, not localhost.
# CSRF_TRUSTED_ORIGINS=https://your-tunnel-domain.ngrok-free.dev

# Firebase push notifications for the staff mobile app (optional - push is a no-op if unset)
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Beta mode: when true, every account gets full access to every plan's features for
# free, and the checkout page shows a "beta" notice instead of real Paddle checkout.
# Turn off once billing should actually start charging people.
# BETA_MODE=False

# Paddle billing (optional - checkout 404s if unset)
# PADDLE_ENV=sandbox
# PADDLE_API_KEY=
# PADDLE_CLIENT_TOKEN=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_PRICE_BASIC=
# PADDLE_PRICE_PRO=
# PADDLE_PRICE_BUSINESS=
